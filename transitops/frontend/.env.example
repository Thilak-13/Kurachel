# Base URL for the Kurachel backend API.
# The frontend API client (src/services/apiClient.js) reads this at build time
# via import.meta.env.VITE_API_BASE_URL and falls back to the value below.
# Copy this file to `.env` (or `.env.local`) and adjust per environment.
VITE_API_BASE_URL=http://localhost:5000/api
